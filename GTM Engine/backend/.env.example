# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://gtm_user:gtm_password@localhost:5432/gtm_db
DATABASE_URL_SYNC=postgresql+psycopg2://gtm_user:gtm_password@localhost:5432/gtm_db

# SQLite fallback (used when DATABASE_URL is not set)
SQLITE_URL=sqlite+aiosqlite:///./gtm_dev.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Anthropic / Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# HubSpot
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_PORTAL_ID=your-portal-id
HUBSPOT_WEBHOOK_SECRET=your-webhook-secret

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_PARTNERSHIPS_CHANNEL=#partnerships

# Google (Sheets + Gmail)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
GOOGLE_CREDENTIALS_FILE=./google_credentials.json

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
